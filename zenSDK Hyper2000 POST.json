        "id": "4a7ea0bd668da74f",
        "type": "function",
        "z": "7b283a64e97a52e9",
        "name": "OutputLimit",
        "func": "const value = Number(msg.payload.properties.outputLimit) || 0;\n\nlet payload = msg.payload; // bestaande payload onthouden\n\nif (isNaN(value)) {\n    payload.properties.outputLimit = 0\n} else {\n    payload.properties.outputLimit = value;\n}\n\nmsg.payload = payload;\nreturn msg;",
