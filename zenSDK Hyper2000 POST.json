        "id": "5b71938202e0993d",
        "type": "function",
        "z": "7b283a64e97a52e9",
        "name": "minSoc",
        "func": "const new_minSoc = msg.payload.properties.minSoc\nconst current_minSoc = msg.payload.minSoc\n\nlet payload = msg.payload; // bestaande payload onthouden\n\nif (new_minSoc > 0) {\n    msg.payload.properties.minSoc = new_minSoc/10;\n} else {\n    msg.payload.properties.minSoc = current_minSoc;\n}\n\nmsg.payload = payload;\nreturn msg;",
