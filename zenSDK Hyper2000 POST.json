    {
        "id": "959b75c395fe1097",
        "type": "function",
        "z": "7b283a64e97a52e9",
        "name": "relaisstand -> acMode",
        "func": "var acMode = msg.payload.properties.acMode;\nvar relaisstand = msg.payload.relaisstand;\n\nlet payload = msg.payload; // bestaande payload onthouden\n\nif (acMode !== \"input\" && acMode !== \"output\") {\n\n   if (relaisstand == \"Ontlaadstand\") {\n      payload.properties.acMode = \"output\";\n   }\n\n   if (relaisstand == \"Oplaadstand\") {\n      payload.properties.acMode = \"input\";\n   }\n}\n\nmsg.payload = payload;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 940,
        "y": 260,
